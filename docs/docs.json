{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TopK",
  "colors": {
    "primary": "#FF5000",
    "light": "#FF5000",
    "dark": "#FF5000"
  },
  "favicon": "/favicon.png",
